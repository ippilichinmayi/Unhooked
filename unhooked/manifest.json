{
  "manifest_version": 3,
  "name": "Unhooked",
  "version": "1.0.0",
  "description": "A Chrome extension for a focused YouTube experience",

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/hidedistractions.js",
        "src/content.jsx"
      ]
    }
  ],

  "action": {
    "default_title": "Unhooked"
  }
}